    "version": "0.2.0",
    "configurations": [    
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "PetClinicApplication-Local-SB",
            "request": "launch",
            "mainClass": "com.eric.common.petclinic.PetClinicApplication",
            "projectName": "spring-cloud-petclinic-service",
            "env": {
                    "MK_IMAGE_PUSH_TARGET": "spring-cloud-petclinic-service:2.8.52-RELEASE",
                    "APP_VERSION": "eVar-Version-Launch-JSON"                    
            }
        },
        {
            "type": "java",
            "name": "PetClinicApplication-Local-K8s",
            "projectName": "spring-cloud-petclinic-service",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005
        }        
    ]
}